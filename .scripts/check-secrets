#!/usr/bin/env bash
set -euo pipefail

TARGET="${1:-.}"
script_dir="$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)"
framework_dir="$(CDPATH='' cd -- "$script_dir/.." && pwd)"
target_dir="$TARGET"
if [ -f "$TARGET" ]; then
  target_dir="$(dirname -- "$TARGET")"
fi
repo_root="$(git -C "$target_dir" rev-parse --show-toplevel 2>/dev/null || true)"
mkdir -p "$framework_dir/tmp"
FAIL_FILE="$(mktemp "$framework_dir/tmp/check-secrets.XXXXXX")"
trap 'rm -f "$FAIL_FILE"' EXIT HUP INT TERM

# High-confidence credential patterns. POSIX character classes only — BSD grep
# does not reliably support \s, \d, \w in ERE.
TOKEN_PATTERN='(-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY|AKIA[0-9A-Z]{16}|ghp_[A-Za-z0-9]{36}|sk_live_[A-Za-z0-9]{20,}|rk_live_[A-Za-z0-9]{20,}|sk_test_[A-Za-z0-9]{24,}|sk-[A-Za-z0-9]{48}|xox[baprs]-[0-9A-Za-z-]{10,48}|ya29\.[0-9A-Za-z_-]+)'

# Heuristic password rule — noisy on fixtures/specs, so suppressed for those paths.
PASSWORD_PATTERN='"password"[[:space:]]*:[[:space:]]*"[^"]{8,}"'

is_example_path() {
  case "$1" in
    *example*|*sample*|*fixture*|*mocks*|*.test.*|*_test.*|*/tests/*|*/test/*|*/__tests__/*|*.md|*.rst|*.txt)
      return 0
      ;;
  esac
  return 1
}

check_file() {
  local file="$1"
  [ -f "$file" ] || return 0

  local basename
  basename="$(basename "$file")"
  case "$basename" in
    .env|*.pem|*.key|*.p12|*.pfx|*.jks|*.keystore)
      case "$basename" in
        *.example|*.sample|*.template) ;;
        *)
          printf 'SECRET: blocked file: %s\n' "$file"
          printf '1\n' > "$FAIL_FILE"
          return 0
          ;;
      esac
      ;;
  esac

  local pattern="$TOKEN_PATTERN"
  if ! is_example_path "$file"; then
    pattern="${TOKEN_PATTERN}|${PASSWORD_PATTERN}"
  fi

  local hits
  hits="$(grep -nEi "$pattern" "$file" 2>/dev/null | cut -d: -f1 | tr '\n' ',' || true)"
  hits="${hits%,}"
  if [ -n "$hits" ]; then
    printf 'SECRET: potential credential in %s at line(s): %s\n' "$file" "$hits"
    printf '1\n' > "$FAIL_FILE"
  fi
}

# Use -print0 / read -d '' so filenames containing whitespace or newlines are safe.
while IFS= read -r -d '' f; do
  if [ -n "$repo_root" ]; then
    rel_path="$f"
    case "$rel_path" in
      "$repo_root"/*) rel_path="${rel_path#"$repo_root"/}" ;;
      ./*) rel_path="${rel_path#./}" ;;
    esac
    if git -C "$repo_root" check-ignore -q -- "$rel_path"; then
      continue
    fi
  fi
  check_file "$f"
done < <(find "$TARGET" -type f \
  ! -path '*/.git/*' ! -path '*/node_modules/*' ! -path '*/.next/*' \
  ! -path '*/dist/*' ! -path '*/build/*' ! -path '*/target/*' \
  ! -path '*/.venv/*' ! -path '*/__pycache__/*' ! -path '*/.pytest_cache/*' \
  ! -path '*/coverage/*' ! -path '*/*.egg-info/*' -print0)

if [ -s "$FAIL_FILE" ]; then
  echo "Secret scan failed. Remove secrets before committing or pushing."
  exit 1
fi
echo "Secret scan passed."
